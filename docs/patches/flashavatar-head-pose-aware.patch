+    def _extract_bbox_payload(self, d: dict) -> Optional[dict]:
+        """Collect optional bbox metadata from a tracker output.
+
+        FLARE's extraction scripts may save extra keys describing where the
+        face was cropped from the original frame.  They are optional and this
+        returns ``None`` when none are present so legacy tracker outputs
+        still work.
+
+        Expected keys (any subset):
+            bbox_center    (2,)  center (cx, cy) in original image pixels
+            bbox_scale     (1,)  short side length of the crop in original px
+            img_size       (2,)  original frame size (W, H)
+            crop_bbox      (4,)  fixed crop rectangle (x1, y1, x2, y2) in
+                                  original image pixels
+            crop_img_size  (2,)  size (W, H) of the cropped image saved in
+                                  ``imgs/`` (i.e. what FlashAvatar renders)
+        """
+        bbox_keys = (
+            "bbox_center",
+            "bbox_scale",
+            "img_size",
+            "crop_bbox",
+            "crop_img_size",
+        )
+        payload: dict = {}
+        for key in bbox_keys:
+            if key in d and d[key] is not None:
+                payload[key] = d[key]
+        return payload if payload else None
+
+    def _shift_K_to_bbox(
+        self,
+        K: torch.Tensor,
+        bbox_payload: dict,
+        img_size: tuple[int, int],
+    ) -> torch.Tensor:
+        """Shift the principal point of ``K`` so the rendered head lines up
+        with the detected bbox center inside the fixed crop image.
+
+        The inputs are expressed in the *original* image coordinate system;
+        ``img_size`` is the rendered image size (matches FlashAvatar's
+        ``--image_res`` and the fixed-cropped ``imgs/`` pixels).  When the
+        fixed crop rectangle is supplied we map the bbox center into the
+        rendered image space; otherwise we leave ``K`` untouched.
+        """
+        if "bbox_center" not in bbox_payload:
+            return K
+        bbox_center = bbox_payload["bbox_center"].to(K.device).float()
+        crop_bbox = bbox_payload.get("crop_bbox")
+        crop_img_size = bbox_payload.get("crop_img_size")
+        if crop_bbox is None or crop_img_size is None:
+            return K
+
+        crop_bbox = crop_bbox.to(K.device).float()
+        crop_img_size = crop_img_size.to(K.device).float()
+        fx1, fy1, fx2, _ = crop_bbox.view(-1)[:4]
+        crop_w = (fx2 - fx1).clamp(min=1.0)
+        scale_x = float(img_size[0]) / float(crop_w)
+        scale_y = float(img_size[1]) / float(crop_w)  # square fixed crop
+
+        cx_crop = (bbox_center[0] - fx1) * scale_x
+        cy_crop = (bbox_center[1] - fy1) * scale_y
+
+        K_shifted = K.clone()
+        K_shifted[:, 0, 2] = cx_crop
+        K_shifted[:, 1, 2] = cy_crop
+        return K_shifted
+
